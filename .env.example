# MySQL local
DB_HOST=localhost
DB_PORT=3306
DB_NAME=facturacion_db
DB_USER=root
DB_PASSWORD=root
# Optional full JDBC URL override (Railway):
# DB_URL=jdbc:mysql://host:3306/db?useSSL=true&allowPublicKeyRetrieval=true&serverTimezone=UTC

# Runtime profile
SPRING_PROFILES_ACTIVE=dev
APP_BASE_URL=http://localhost:8080

# JWT
JWT_SECRET=change_me_please_change_me_please_change_me_please
JWT_ACCESS_EXP_MIN=30
JWT_REFRESH_EXP_DAYS=7

# Email (SendGrid SMTP)
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=replace_with_sendgrid_api_key
MAIL_FROM=no-reply@facturacion.local

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Frontend
VITE_API_URL=http://localhost:8080
